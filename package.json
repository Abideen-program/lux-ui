{
  "name": "lux-ui",
  "version": "0.1.0",
  "description": "Beautiful React component library powered by luxcss. 63+ components with glass, neon, aurora and motion built in.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "react", "component-library", "ui", "luxcss",
    "design-system", "glass", "neon", "animations",
    "nextjs", "typescript"
  ],
  "author": "Abideen",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "luxcss": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "tsup": "^8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abideen-program/lux-ui.git"
  },
  "homepage": "https://lux-ui.dev",
  "sideEffects": false
}
