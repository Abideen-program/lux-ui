{
  "name": "lux-ui",
  "version": "0.1.0",
  "description": "Beautiful React component library powered by luxcss. 63+ components with glass, neon, aurora and motion built in.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react", "component-library", "ui", "luxcss",
    "design-system", "glass", "neon", "animations",
    "nextjs", "typescript"
  ],
  "author": "Abideen",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "luxcss": ">=2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "tsup": "^8",
    "vitest": "^2",
    "@vitejs/plugin-react": "^4",
    "@testing-library/react": "^16",
    "@testing-library/jest-dom": "^6",
    "@testing-library/user-event": "^14",
    "jsdom": "^25"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abideen-program/lux-ui.git"
  },
  "homepage": "https://lux-ui.dev",
  "sideEffects": false
}
